@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vault:   <https://example.com/vault/ontology#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vs:      <https://example.com/vault/shapes/> .

# =============================================================================
# Vault Shapes — SHACL validation constraints + SPARQL materialization rules
#
# Three concerns in one file:
#   1. NodeShapes with sh:property  — structural validation
#   2. sh:SPARQLConstraint           — complex validation (cross-node)
#   3. sh:SPARQLRule with sh:construct — materialization of implied triples
#
# Usage:
#   Validate:     shacl validate --shapes=vault-shapes.ttl --data=vault-graph.ttl
#   Materialize:  shacl infer --shapes=vault-shapes.ttl --data=vault-graph.ttl
# =============================================================================

# --- Prefix declarations for embedded SPARQL ---

vs:Prefixes a sh:PrefixDeclaration ;
    sh:declare
        [ sh:prefix "vault"   ; sh:namespace "https://example.com/vault/ontology#"^^xsd:anyURI ] ,
        [ sh:prefix "dcterms" ; sh:namespace "http://purl.org/dc/terms/"^^xsd:anyURI ] ,
        [ sh:prefix "rdf"     ; sh:namespace "http://www.w3.org/1999/02/22-rdf-syntax-ns#"^^xsd:anyURI ] ,
        [ sh:prefix "rdfs"    ; sh:namespace "http://www.w3.org/2000/01/rdf-schema#"^^xsd:anyURI ] ,
        [ sh:prefix "xsd"     ; sh:namespace "http://www.w3.org/2001/XMLSchema#"^^xsd:anyURI ] .

# =============================================================================
# Layer 1: Structural Validation — sh:property constraints
# =============================================================================

# --- Every note must have a title ---

vs:NoteShape a sh:NodeShape ;
    sh:targetSubjectsOf rdf:type ;
    rdfs:comment "Base shape: every typed note must have a title." ;
    sh:property [
        sh:path dcterms:title ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Every note must have exactly one dcterms:title." ;
    ] .

# --- Projects must have an area of focus ---

vs:ProjectShape a sh:NodeShape ;
    sh:targetClass vault:Project ;
    rdfs:comment "Projects must connect to an area of focus (Pullein methodology)." ;
    sh:property [
        sh:path vault:area ;
        sh:minCount 1 ;
        sh:message "Project is missing vault:area — every project must serve an area of focus." ;
        sh:severity sh:Warning ;
    ] ;
    sh:property [
        sh:path vault:status ;
        sh:minCount 1 ;
        sh:message "Project is missing vault:status." ;
        sh:severity sh:Info ;
    ] .

# --- MOCs must have up: to a parent ---

vs:MOCShape a sh:NodeShape ;
    sh:targetClass vault:MOC ;
    rdfs:comment "MOCs must have an up: link to their parent (another MOC or VAULT-INDEX)." ;
    sh:property [
        sh:path vault:up ;
        sh:minCount 1 ;
        sh:message "MOC is missing vault:up — needs a parent in the hierarchy." ;
        sh:severity sh:Warning ;
    ] .

# --- Literature notes must have up: ---

vs:LiteratureNoteShape a sh:NodeShape ;
    sh:targetClass vault:LiteratureNote ;
    rdfs:comment "Literature notes must link up to a MOC or index." ;
    sh:property [
        sh:path vault:up ;
        sh:minCount 1 ;
        sh:message "Literature note is missing vault:up — needs a parent MOC or index." ;
        sh:severity sh:Warning ;
    ] .

# --- Theory notes should have source: or extends: ---

vs:TheoryNoteShape a sh:NodeShape ;
    sh:targetClass vault:TheoryNote ;
    rdfs:comment "Theory notes should cite sources or extend other theories." ;
    sh:property [
        sh:path vault:up ;
        sh:minCount 1 ;
        sh:message "Theory note is missing vault:up — needs a parent MOC." ;
        sh:severity sh:Warning ;
    ] .

# --- Author notes must have up: ---

vs:AuthorNoteShape a sh:NodeShape ;
    sh:targetClass vault:AuthorNote ;
    rdfs:comment "Author notes must link up to a MOC or index (typically LITERATURE-INDEX)." ;
    sh:property [
        sh:path vault:up ;
        sh:minCount 1 ;
        sh:message "Author note is missing vault:up — should point to LITERATURE-INDEX or relevant MOC." ;
        sh:severity sh:Warning ;
    ] .

# --- Person notes should have affiliation: ---

vs:PersonShape a sh:NodeShape ;
    sh:targetClass vault:Person ;
    rdfs:comment "Person notes should have an affiliation." ;
    sh:property [
        sh:path vault:affiliation ;
        sh:minCount 1 ;
        sh:message "Person is missing vault:affiliation — consider adding their organization." ;
        sh:severity sh:Info ;
    ] .

# --- Areas must have up: to VAULT-INDEX ---

vs:AreaShape a sh:NodeShape ;
    sh:targetClass vault:Area ;
    rdfs:comment "Areas of focus must link up to VAULT-INDEX." ;
    sh:property [
        sh:path vault:up ;
        sh:minCount 1 ;
        sh:message "Area is missing vault:up — should point to VAULT-INDEX." ;
        sh:severity sh:Warning ;
    ] .

# =============================================================================
# Layer 2: Complex Validation — sh:SPARQLConstraint
# =============================================================================

# --- Detect notes that point to nonexistent targets ---

vs:DanglingReferenceConstraint a sh:NodeShape ;
    sh:targetSubjectsOf rdf:type ;
    rdfs:comment "Detect edge fields pointing to URIs that have no type (not in the graph as typed notes)." ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:prefixes vs:Prefixes ;
        sh:message "Edge field points to {?target} which has no type in the graph (possible dangling reference)." ;
        sh:severity sh:Info ;
        sh:select """
            SELECT $this ?target WHERE {
                $this ?pred ?target .
                FILTER(?pred IN (vault:up, vault:area, vault:concept, vault:source,
                                 vault:extends, vault:supports, vault:criticizes,
                                 vault:implementation, vault:related,
                                 vault:author, vault:affiliation, vault:collaborator))
                FILTER(isIRI(?target))
                FILTER NOT EXISTS { ?target a ?anyType . }
            }
        """ ;
    ] .

# =============================================================================
# Layer 3: Materialization Rules — sh:SPARQLRule
# =============================================================================

# --- Transitive vault:up closure ---
# If A vault:up B and B vault:up C, then A vault:up C (for hierarchy traversal)

vs:TransitiveUpRule a sh:NodeShape ;
    sh:targetSubjectsOf vault:up ;
    rdfs:comment "Materialize transitive closure of vault:up for hierarchy queries." ;
    sh:rule [
        a sh:SPARQLRule ;
        sh:prefixes vs:Prefixes ;
        sh:construct """
            CONSTRUCT { $this vault:up ?ancestor . }
            WHERE {
                $this vault:up+ ?ancestor .
                FILTER(?ancestor != $this)
            }
        """ ;
    ] .

# --- Area inheritance: propagate area down the up: hierarchy ---
# If A vault:up B and B vault:area C, then A vault:area C

vs:AreaInheritanceRule a sh:NodeShape ;
    sh:targetSubjectsOf vault:up ;
    rdfs:comment "Inherit area from parent: if a note's parent has vault:area, the note inherits it." ;
    sh:rule [
        a sh:SPARQLRule ;
        sh:prefixes vs:Prefixes ;
        sh:construct """
            CONSTRUCT { $this vault:area ?area . }
            WHERE {
                $this vault:up+ ?ancestor .
                ?ancestor vault:area ?area .
                FILTER NOT EXISTS { $this vault:area ?area . }
            }
        """ ;
    ] .

# --- Inverse supports/criticizes edges ---
# If A vault:supports B, materialize B vault:supportedBy A

vs:InverseSupportRule a sh:NodeShape ;
    sh:targetObjectsOf vault:supports ;
    rdfs:comment "Materialize inverse: if A supports B, then B supportedBy A." ;
    sh:rule [
        a sh:SPARQLRule ;
        sh:prefixes vs:Prefixes ;
        sh:construct """
            CONSTRUCT { $this vault:supportedBy ?source . }
            WHERE { ?source vault:supports $this . }
        """ ;
    ] .

vs:InverseCriticizeRule a sh:NodeShape ;
    sh:targetObjectsOf vault:criticizes ;
    rdfs:comment "Materialize inverse: if A criticizes B, then B criticizedBy A." ;
    sh:rule [
        a sh:SPARQLRule ;
        sh:prefixes vs:Prefixes ;
        sh:construct """
            CONSTRUCT { $this vault:criticizedBy ?source . }
            WHERE { ?source vault:criticizes $this . }
        """ ;
    ] .

# --- Inverse concept edges ---
# If A vault:concept B, materialize B vault:conceptOf A

vs:InverseConceptRule a sh:NodeShape ;
    sh:targetObjectsOf vault:concept ;
    rdfs:comment "Materialize inverse: if A references concept B, then B conceptOf A." ;
    sh:rule [
        a sh:SPARQLRule ;
        sh:prefixes vs:Prefixes ;
        sh:construct """
            CONSTRUCT { $this vault:conceptOf ?source . }
            WHERE { ?source vault:concept $this . }
        """ ;
    ] .

# --- Inverse author edges ---
# If A vault:author B, materialize B vault:authorOf A

vs:InverseAuthorRule a sh:NodeShape ;
    sh:targetObjectsOf vault:author ;
    rdfs:comment "Materialize inverse: if A has author B, then B authorOf A." ;
    sh:rule [
        a sh:SPARQLRule ;
        sh:prefixes vs:Prefixes ;
        sh:construct """
            CONSTRUCT { $this vault:authorOf ?work . }
            WHERE { ?work vault:author $this . }
        """ ;
    ] .

# --- Subclass materialization: AuthorNote inherits Person type ---
# Every vault:AuthorNote is also a vault:Person

vs:AuthorIsPersonRule a sh:NodeShape ;
    sh:targetClass vault:AuthorNote ;
    rdfs:comment "Materialize: every AuthorNote is also a Person (for queries targeting vault:Person)." ;
    sh:rule [
        a sh:SPARQLRule ;
        sh:prefixes vs:Prefixes ;
        sh:construct """
            CONSTRUCT { $this a vault:Person . }
            WHERE { $this a vault:AuthorNote . }
        """ ;
    ] .

# --- Hub detection: materialize a vault:hubScore for highly connected nodes ---

vs:HubDetectionRule a sh:NodeShape ;
    sh:targetSubjectsOf rdf:type ;
    rdfs:comment "Tag notes with high inbound edge count as hubs (for navigation prioritization)." ;
    sh:rule [
        a sh:SPARQLRule ;
        sh:prefixes vs:Prefixes ;
        sh:construct """
            CONSTRUCT { $this vault:isHub true . }
            WHERE {
                {
                    SELECT $this (COUNT(?src) AS ?inbound) WHERE {
                        ?src ?pred $this .
                        FILTER(?pred IN (vault:up, vault:area, vault:concept, vault:source,
                                         vault:extends, vault:supports, vault:criticizes,
                                         vault:implementation, vault:related,
                                         vault:author, vault:affiliation, vault:collaborator))
                    } GROUP BY $this
                }
                FILTER(?inbound >= 10)
            }
        """ ;
    ] .
