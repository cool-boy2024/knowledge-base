# Find all notes connected to a concept by title substring. Returns note title, type, and relation. Used by Retrieve targeted mode. Replace CONCEPT_SUBSTRING.
PREFIX vault: <https://example.com/vault/ontology#>
PREFIX dcterms: <http://purl.org/dc/terms/>
SELECT ?note ?noteTitle ?noteType ?relation WHERE {
    ?concept dcterms:title ?conceptTitle .
    FILTER(CONTAINS(LCASE(?conceptTitle), LCASE("CONCEPT_SUBSTRING")))
    {
        ?note vault:concept ?concept .
        BIND("references" AS ?relation)
    } UNION {
        ?note vault:supports ?concept .
        BIND("supports" AS ?relation)
    } UNION {
        ?note vault:criticizes ?concept .
        BIND("criticizes" AS ?relation)
    } UNION {
        ?note vault:extends ?concept .
        BIND("extends" AS ?relation)
    }
    ?note a ?noteType .
    ?note dcterms:title ?noteTitle .
    FILTER EXISTS { ?note a ?t }
} ORDER BY ?relation ?noteTitle
