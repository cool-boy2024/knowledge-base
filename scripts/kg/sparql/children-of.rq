# List all notes whose vault:up points to a given parent. Replace PARENT_SLUG with the URI slug (e.g. 'Agentic-Memory-Systems-MOC').
PREFIX vault: <https://example.com/vault/ontology#>
PREFIX dcterms: <http://purl.org/dc/terms/>
SELECT ?note ?type ?title WHERE {
    ?note vault:up <https://example.com/vault/notes/PARENT_SLUG> .
    ?note a ?type .
    ?note dcterms:title ?title .
} ORDER BY ?type ?title
