# Overall graph statistics: total triples, total typed notes, total edges.
PREFIX vault: <https://example.com/vault/ontology#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
SELECT
    (COUNT(*) AS ?totalTriples)
    (COUNT(DISTINCT ?note) AS ?typedNotes)
WHERE {
    { ?s ?p ?o }
    UNION
    { ?note a ?type }
}
