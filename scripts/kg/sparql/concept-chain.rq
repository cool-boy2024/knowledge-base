# Multi-hop: find literature -> concept -> implementation chains. Discovers how papers connect to code via concepts.
PREFIX vault: <https://example.com/vault/ontology#>
PREFIX dcterms: <http://purl.org/dc/terms/>
SELECT ?paper ?paperTitle ?concept ?conceptTitle ?impl ?implTitle WHERE {
    ?paper vault:concept ?concept .
    ?paper dcterms:title ?paperTitle .
    ?concept dcterms:title ?conceptTitle .
    OPTIONAL {
        ?concept vault:implementation ?impl .
        ?impl dcterms:title ?implTitle .
    }
} ORDER BY ?conceptTitle
