# 2-hop neighbors with low inbound edge count (< 5), excluding hubs. Surfaces underexplored notes in a concept's neighborhood. Replace NOTE_URI. Used by Retrieve exploratory mode.
PREFIX vault: <https://example.com/vault/ontology#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
SELECT ?neighbor ?neighborTitle ?neighborType ?inbound ?path WHERE {
    {
        <NOTE_URI> vault:concept ?concept .
        ?neighbor vault:concept ?concept .
        FILTER(?neighbor != <NOTE_URI>)
        BIND("shared-concept" AS ?path)
    } UNION {
        <NOTE_URI> vault:up ?moc .
        ?neighbor vault:up ?moc .
        FILTER(?neighbor != <NOTE_URI>)
        BIND("sibling-under-moc" AS ?path)
    }
    ?neighbor dcterms:title ?neighborTitle .
    ?neighbor a ?neighborType .
    FILTER NOT EXISTS { ?neighbor vault:isHub true }
    FILTER EXISTS { ?neighbor a ?anyType }
    {
        SELECT ?neighbor (COUNT(?src) AS ?inbound) WHERE {
            ?src ?pred ?neighbor .
            FILTER(?pred NOT IN (
                rdf:type, dcterms:title, dcterms:created,
                vault:tag, vault:status, vault:timeline
            ))
        } GROUP BY ?neighbor
    }
    FILTER(?inbound < 5)
} ORDER BY ?inbound ?neighborTitle
LIMIT 15
